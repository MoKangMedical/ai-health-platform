# AI健康平台环境配置

# 基础配置
APP_NAME=AI Health Platform
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8200

# 数据库配置
DATABASE_URL=sqlite:///./ai_health.db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI模型配置
VOICE_MODEL_PATH=models/voice_model.pth
FACE_MODEL_PATH=models/face_model.pth
KNOWLEDGE_GRAPH_PATH=data/knowledge_graph.json

# 外部服务配置
VOICE_HEALTH_API=http://localhost:8100
MEDICHAT_API=http://localhost:8300
KNOWHEALTH_API=http://localhost:8080

# 营养品配置
INGREDIENT_DB_PATH=data/ingredients.json
MAX_FORMULA_INGREDIENTS=15

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
